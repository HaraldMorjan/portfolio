---
import StackContent from "./sections/StackContent.astro";
import { DEFAULT_LANG } from "../data/i18n.js";

const { lang = DEFAULT_LANG } = Astro.props;
---

<section id="stack" class="border-y border-border bg-surface/50">
  <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
    <StackContent lang={lang} />
  </div>
</section>
