---
import { profile } from "../data/portfolio";

const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-2 px-4 py-8 text-sm text-muted sm:flex-row sm:px-6"
  >
    <p>&copy; {year} {profile.name}. All rights reserved.</p>
    <p class="font-mono">
      Built with <a
        href="https://astro.build"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">Astro</a
      > &amp; <a
        href="https://tailwindcss.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline">Tailwind</a
      >
    </p>
  </div>
</footer>
