---
import { getPortfolio } from "../data/portfolio";
import { getUi, DEFAULT_LANG } from "../data/i18n.js";
import SocialLinks from "./SocialLinks.astro";

const { lang = DEFAULT_LANG } = Astro.props;
const { socials, profile } = getPortfolio(lang);
const ui = getUi(lang);
const t = ui.contact;
const available = ui.hero.available;

const emailHref =
  socials.find((s) => s.label === "Email")?.href ?? "mailto:you@example.com";
const emailAddr = emailHref.replace(/^mailto:/, "");

const resumeUrl = profile.resumeUrl || "";
const calendarUrl = profile.calendarUrl || "";
---

<section id="contact" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
  <div
    class="relative overflow-hidden rounded-3xl border border-border px-6 py-14 text-center shadow-lg sm:px-12"
    style="background-image: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 65%, #000));"
  >
    <!-- Decorative dotted glow -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.18] [background-image:radial-gradient(circle_at_1px_1px,var(--accent-contrast)_1px,transparent_0)] [background-size:22px_22px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
      aria-hidden="true"
    >
    </div>

    <div class="relative">
      <h2 class="text-3xl font-bold text-accent-contrast sm:text-4xl">{t.title}</h2>
      <p class="mx-auto mt-3 max-w-xl text-lg text-accent-contrast/90">
        {t.intro}
      </p>

      <!-- Trust chips -->
      <ul class="mx-auto mt-7 flex max-w-2xl flex-wrap items-center justify-center gap-2.5">
        <li class="inline-flex items-center gap-2 rounded-full border border-accent-contrast/25 bg-accent-contrast/10 px-3 py-1 text-xs font-medium text-accent-contrast backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-contrast opacity-60"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-accent-contrast"></span>
          </span>
          {available}
        </li>
        <li class="inline-flex items-center gap-1.5 rounded-full border border-accent-contrast/25 bg-accent-contrast/10 px-3 py-1 text-xs font-medium text-accent-contrast backdrop-blur-sm">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          {profile.location}
        </li>
        <li class="inline-flex items-center gap-1.5 rounded-full border border-accent-contrast/25 bg-accent-contrast/10 px-3 py-1 text-xs font-medium text-accent-contrast backdrop-blur-sm">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8" />
            <path d="M3 3v5h5" />
          </svg>
          {t.replyTime}
        </li>
        <li class="inline-flex items-center gap-1.5 rounded-full border border-accent-contrast/25 bg-accent-contrast/10 px-3 py-1 text-xs font-medium text-accent-contrast backdrop-blur-sm">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M2 12h20" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
          </svg>
          {t.remoteFriendly}
        </li>
        <li
          class="inline-flex items-center gap-1.5 rounded-full border border-accent-contrast/25 bg-accent-contrast/10 px-3 py-1 text-xs font-medium text-accent-contrast backdrop-blur-sm"
          title={t.localTime}
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 6v6l4 2" />
          </svg>
          <span class="sr-only">{t.localTime}:</span>
          <span id="local-time" data-tz="America/Guatemala" data-locale={lang}>--:--</span>
        </li>
      </ul>

      <div class="mt-9 flex flex-col items-center justify-center gap-5">
        <button
          type="button"
          data-contact-open
          class="inline-flex items-center gap-2 rounded-lg bg-bg px-6 py-3 text-sm font-semibold text-accent shadow-sm transition hover:-translate-y-0.5 hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-contrast"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2" />
            <path d="m22 7-10 6L2 7" />
          </svg>
          {t.sayHello}
        </button>

        <!-- Secondary actions: résumé + booking -->
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href={resumeUrl || undefined}
            download={resumeUrl ? true : undefined}
            aria-disabled={resumeUrl ? undefined : "true"}
            title={resumeUrl ? undefined : t.soon}
            class:list={[
              "inline-flex items-center gap-2 rounded-lg border border-accent-contrast/40 px-5 py-2.5 text-sm font-semibold text-accent-contrast transition",
              resumeUrl
                ? "hover:-translate-y-0.5 hover:bg-accent-contrast/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-contrast"
                : "cursor-not-allowed opacity-60",
            ]}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <path d="M7 10l5 5 5-5" />
              <path d="M12 15V3" />
            </svg>
            {t.resume}
          </a>
          <a
            href={calendarUrl || undefined}
            target={calendarUrl ? "_blank" : undefined}
            rel={calendarUrl ? "noopener noreferrer" : undefined}
            aria-disabled={calendarUrl ? undefined : "true"}
            title={calendarUrl ? undefined : t.soon}
            class:list={[
              "inline-flex items-center gap-2 rounded-lg border border-accent-contrast/40 px-5 py-2.5 text-sm font-semibold text-accent-contrast transition",
              calendarUrl
                ? "hover:-translate-y-0.5 hover:bg-accent-contrast/10 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-contrast"
                : "cursor-not-allowed opacity-60",
            ]}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" />
              <path d="M16 2v4M8 2v4M3 10h18" />
            </svg>
            {t.book}
          </a>
        </div>

        <!-- Direct email with copy-to-clipboard -->
        <div class="flex flex-wrap items-center justify-center gap-2 text-sm text-accent-contrast/85">
          <span>{t.emailDirect}</span>
          <button
            id="copy-email"
            type="button"
            data-email={emailAddr}
            data-copied={t.copied}
            class="group inline-flex items-center gap-1.5 rounded-lg border border-accent-contrast/30 bg-accent-contrast/10 px-2.5 py-1 font-mono text-accent-contrast transition hover:bg-accent-contrast/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-contrast"
          >
            <span class="copy-email-text">{emailAddr}</span>
            <svg class="copy-icon h-3.5 w-3.5 opacity-70 transition group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
            </svg>
            <svg class="copy-check hidden h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6 9 17l-5-5" />
            </svg>
          </button>
        </div>

        <SocialLinks
          emailAsForm
          class="justify-center [&_a]:border-accent-contrast/30 [&_a]:text-accent-contrast hover:[&_a]:bg-accent-contrast/10 [&_button]:border-accent-contrast/30 [&_button]:text-accent-contrast hover:[&_button]:bg-accent-contrast/10"
        />
      </div>
    </div>
  </div>
</section>

<script>
  // @ts-nocheck
  // Live local time for the portfolio owner (so visitors know if I'm around).
  const timeEl = document.getElementById("local-time");
  if (timeEl) {
    const tz = timeEl.dataset.tz || "America/Guatemala";
    const locale = timeEl.dataset.locale || "en";
    const tick = () => {
      try {
        const parts = new Intl.DateTimeFormat(locale, {
          hour: "2-digit",
          minute: "2-digit",
          timeZone: tz,
          timeZoneName: "short",
        }).formatToParts(new Date());
        const get = (type) => parts.find((p) => p.type === type)?.value || "";
        const time = `${get("hour")}:${get("minute")}${get("dayPeriod") ? " " + get("dayPeriod") : ""}`;
        const zone = get("timeZoneName");
        timeEl.textContent = zone ? `${time} (${zone})` : time;
      } catch (e) {
        /* Intl/timezone unsupported — leave placeholder */
      }
    };
    tick();
    setInterval(tick, 30000);
  }

  const btn = document.getElementById("copy-email");
  if (btn && navigator.clipboard) {
    const textEl = btn.querySelector(".copy-email-text");
    const copyIcon = btn.querySelector(".copy-icon");
    const checkIcon = btn.querySelector(".copy-check");
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.email);
      } catch (e) {
        return;
      }
      const original = textEl.textContent;
      textEl.textContent = btn.dataset.copied || "Copied!";
      copyIcon?.classList.add("hidden");
      checkIcon?.classList.remove("hidden");
      setTimeout(() => {
        textEl.textContent = original;
        checkIcon?.classList.add("hidden");
        copyIcon?.classList.remove("hidden");
      }, 1500);
    });
  }
</script>
