---
import { socials } from "../data/portfolio";
import SocialLinks from "./SocialLinks.astro";

const email = socials.find((s) => s.label === "Email")?.href ?? "mailto:you@example.com";
---

<section id="contact" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-24">
  <div
    class="relative overflow-hidden rounded-3xl border border-border px-6 py-14 text-center shadow-lg sm:px-12"
    style="background-image: linear-gradient(135deg, var(--accent), color-mix(in srgb, var(--accent) 65%, #000));"
  >
    <h2 class="text-3xl font-bold text-accent-contrast sm:text-4xl">Let's build something</h2>
    <p class="mx-auto mt-3 max-w-xl text-lg text-accent-contrast/90">
      Have a project in mind, a role to fill, or just want to say hi? My inbox is
      always open.
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4">
      <a
        href={email}
        class="inline-flex items-center gap-2 rounded-lg bg-bg px-6 py-3 text-sm font-semibold text-accent shadow-sm transition hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-contrast"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-10 6L2 7" />
        </svg>
        Say hello
      </a>
      <SocialLinks class="justify-center [&_a]:border-accent-contrast/30 [&_a]:text-accent-contrast hover:[&_a]:bg-accent-contrast/10" />
    </div>
  </div>
</section>
