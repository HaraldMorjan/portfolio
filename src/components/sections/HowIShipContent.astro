---
import { DEFAULT_LANG, getUi } from "../../data/i18n.js";

const { lang = DEFAULT_LANG } = Astro.props;
const shipping = getUi(lang).projects.shipping;
const cloudflare = shipping.cloudflare;
const pipelineTools = ["GitHub Actions", "Cloudflare", "DonDominio FTPS"];
---

<section
    id="how-i-ship"
    aria-labelledby="how-i-ship-title"
    class="overflow-hidden rounded-2xl border border-border bg-surface shadow-sm"
>
    <div class="grid gap-8 p-6 sm:p-8 lg:grid-cols-[1fr_auto] lg:items-start">
        <div>
            <p
                class="text-xs font-semibold uppercase tracking-widest text-accent"
            >
                {shipping.eyebrow}
            </p>
            <h2
                id="how-i-ship-title"
                class="mt-2 text-xl font-bold text-text sm:text-2xl"
            >
                {shipping.title}
            </h2>
            <p
                class="mt-3 max-w-2xl text-sm leading-relaxed text-muted sm:text-base"
            >
                {shipping.intro}
            </p>

            <ol class="mt-6 grid gap-4 sm:grid-cols-2">
                {
                    shipping.steps.map((step, index) => (
                        <li class="flex gap-3 rounded-xl border border-border bg-bg/60 p-4">
                            <span
                                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-strong text-sm font-bold text-accent-contrast"
                                aria-hidden="true"
                            >
                                {index + 1}
                            </span>
                            <div>
                                <p class="font-semibold text-text">
                                    {step.title}
                                </p>
                                <p class="mt-1 text-sm leading-relaxed text-muted">
                                    {step.description}
                                </p>
                            </div>
                        </li>
                    ))
                }
            </ol>

            <div
                class="mt-6 rounded-xl border border-orange-500/35 bg-orange-500/8 p-5 sm:p-6"
            >
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-orange-600 dark:text-orange-300"
                >
                    {cloudflare.eyebrow}
                </p>
                <h3 class="mt-2 text-lg font-bold text-text">
                    {cloudflare.title}
                </h3>
                <p
                    class="mt-2 max-w-2xl text-sm leading-relaxed text-muted sm:text-base"
                >
                    {cloudflare.intro}
                </p>

                <ul class="mt-5 grid gap-3 sm:grid-cols-2">
                    {
                        cloudflare.items.map((item) => (
                            <li class="rounded-lg border border-orange-500/20 bg-bg/70 p-4">
                                <p class="font-semibold text-text">
                                    {item.label}
                                </p>
                                <p class="mt-1 text-sm leading-relaxed text-muted">
                                    {item.detail}
                                </p>
                            </li>
                        ))
                    }
                </ul>

                <p
                    class="mt-5 inline-flex items-start gap-2 text-sm font-medium text-text"
                >
                    <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-orange-500"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                        ></path>
                    </svg>
                    {cloudflare.everyProject}
                </p>
            </div>

            <div class="mt-6">
                <p
                    class="text-xs font-semibold uppercase tracking-widest text-muted"
                >
                    {shipping.pipeline}
                </p>
                <ul class="mt-2 flex flex-wrap gap-2">
                    {
                        pipelineTools.map((tool) => (
                            <li>
                                <span
                                    class:list={[
                                        "inline-flex items-center rounded-lg border px-2.5 py-1 text-xs font-medium",
                                        tool === "Cloudflare"
                                            ? "border-orange-500/35 bg-orange-500/10 text-orange-800 dark:text-orange-200"
                                            : "border-border bg-bg text-text",
                                    ]}
                                >
                                    {tool}
                                </span>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </div>
</section>
