---
import { techStack } from "../../data/portfolio";
import TechStackMarquee from "../react/TechStackMarquee.jsx";
---

<div class="max-w-2xl">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
    Tech stack
  </h2>
  <p class="mt-2 text-3xl font-bold text-text">Technologies I work with</p>
  <p class="mt-3 text-lg text-muted">
    The languages, frameworks, and tools I use to design, build, and ship
    software end to end.
  </p>
</div>

<TechStackMarquee client:visible groups={techStack} />
