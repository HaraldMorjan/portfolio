---
import { getPortfolio } from "../../data/portfolio";
import { getUi, DEFAULT_LANG } from "../../data/i18n.js";
import TechExplorer from "../react/TechExplorer.jsx";

const { lang = DEFAULT_LANG } = Astro.props;
const { techStack } = getPortfolio(lang);
const t = getUi(lang).stack;

const explorerStrings = {
  all: t.all,
  search: t.search,
  builtWith: t.builtWith,
  liveState: t.liveState,
  showing: t.showing,
  technologies: t.technologies,
  noMatches: t.noMatches,
};
---

<div class="max-w-2xl">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
    {t.eyebrow}
  </h2>
  <p class="mt-2 text-3xl font-bold text-text">{t.title}</p>
  <p class="mt-3 text-lg text-muted">{t.intro}</p>
</div>

<TechExplorer client:visible groups={techStack} strings={explorerStrings} />
