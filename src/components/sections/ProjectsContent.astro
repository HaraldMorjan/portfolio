---
import { projects } from "../../data/portfolio";
---

<div class="max-w-2xl">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
    Projects
  </h2>
  <p class="mt-2 text-3xl font-bold text-text">Things I've built</p>
  <p class="mt-3 text-lg text-muted">
    A selection of projects that show how I think and what I can ship.
  </p>
</div>

<div class="mt-10 grid gap-6 sm:grid-cols-2">
  {
    projects.map((project) => (
      <article
        class:list={[
          "flex flex-col rounded-2xl border border-border bg-surface p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md",
          project.featured && "sm:col-span-2",
        ]}
      >
        <div class="flex items-start justify-between gap-4">
          <h3 class="text-xl font-semibold text-text">{project.title}</h3>
          {project.featured && (
            <span class="shrink-0 rounded-full bg-accent/10 px-2.5 py-1 text-xs font-semibold text-accent">
              Featured
            </span>
          )}
        </div>

        <p class="mt-3 flex-1 text-muted">{project.description}</p>

        <ul class="mt-4 flex flex-wrap gap-2">
          {project.tags.map((tag) => (
            <li>
              <span class="inline-flex items-center rounded-md bg-hover px-2 py-0.5 font-mono text-xs text-muted">
                {tag}
              </span>
            </li>
          ))}
        </ul>

        <div class="mt-5 flex items-center gap-4 border-t border-border pt-4">
          {project.repoUrl && (
            <a
              href={project.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View ${project.title} source code on GitHub`}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition hover:text-accent"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
                />
              </svg>
              Code
            </a>
          )}
          {project.liveUrl && (
            <a
              href={project.liveUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`View the ${project.title} live demo`}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition hover:text-accent"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <path d="M15 3h6v6" />
                <path d="M10 14 21 3" />
              </svg>
              Live demo
            </a>
          )}
        </div>
      </article>
    ))
  }
</div>
