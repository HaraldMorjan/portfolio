---
import { getPortfolio } from "../../data/portfolio";
import { getUi, DEFAULT_LANG } from "../../data/i18n.js";
import { resolveTech, brandColorOf, monogram } from "../../data/techIcons.js";

const { lang = DEFAULT_LANG } = Astro.props;
const { projects } = getPortfolio(lang);
const t = getUi(lang).projects;
---

<div class="max-w-2xl">
  <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
    {t.eyebrow}
  </h2>
  <p class="mt-2 text-3xl font-bold text-text">{t.title}</p>
  <p class="mt-3 text-lg text-muted">{t.intro}</p>
</div>

<div class="mt-10 flex flex-col gap-8">
  {
    projects.map((project) => {
      const hasLive = Boolean(project.liveUrl?.trim());
      return (
      <article class="overflow-hidden rounded-2xl border border-border bg-surface shadow-sm transition hover:shadow-md">
        <div
          class:list={[
            hasLive && "grid lg:grid-cols-2 lg:divide-x lg:divide-border",
          ]}
        >
          <div class="flex flex-col p-6 sm:p-8">
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-xl font-semibold text-text sm:text-2xl">
                {project.title}
              </h3>
              {project.featured && (
                <span class="shrink-0 rounded-full bg-accent-strong px-2.5 py-1 text-xs font-semibold text-accent-contrast">
                  {t.featured}
                </span>
              )}
            </div>

            <p class="mt-4 flex-1 text-sm leading-relaxed text-muted sm:text-base">
              {project.description}
            </p>

            <div class="mt-6">
              <p class="mb-2 text-xs font-semibold uppercase tracking-widest text-muted">
                {t.stack}
              </p>
              <ul class="flex flex-wrap gap-2">
                {project.tags.map((tag) => {
                  const icon = resolveTech(tag);
                  const brand = brandColorOf(tag);
                  return (
                    <li>
                      <span
                        class="group/chip inline-flex items-center gap-1.5 rounded-lg border border-border bg-bg px-2.5 py-1 text-xs font-medium text-text transition hover:-translate-y-0.5 hover:[border-color:var(--c)]"
                        style={`--c:${brand || "var(--accent)"}`}
                      >
                        {icon ? (
                          <svg
                            viewBox="0 0 24 24"
                            class="h-4 w-4 transition group-hover/chip:scale-110"
                            style={`fill:${brand || "currentColor"}`}
                            aria-hidden="true"
                          >
                            <path d={icon.path} />
                          </svg>
                        ) : (
                          <span
                            class="grid h-4 w-4 place-items-center rounded text-[0.6rem] font-bold text-accent"
                            aria-hidden="true"
                          >
                            {monogram(tag)}
                          </span>
                        )}
                        {tag}
                      </span>
                    </li>
                  );
                })}
              </ul>
            </div>

            <div class="mt-6 flex flex-wrap items-center gap-4 border-t border-border pt-5">
              {project.repoUrl && (
                <a
                  href={project.repoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={t.viewCode(project.title)}
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition hover:text-accent"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"
                    />
                  </svg>
                  {t.code}
                </a>
              )}
              {project.liveUrl && (
                <a
                  href={project.liveUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={t.viewDemo(project.title)}
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-muted transition hover:text-accent"
                >
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                    <path d="M15 3h6v6" />
                    <path d="M10 14 21 3" />
                  </svg>
                  {t.liveDemo}
                </a>
              )}
            </div>
          </div>

          {hasLive && (
            <div class="relative min-h-[16rem] bg-bg sm:min-h-[18rem] lg:min-h-[20rem]">
              <iframe
                src={project.liveUrl}
                title={t.viewDemo(project.title)}
                class="absolute inset-0 h-full w-full border-0"
                loading="lazy"
                sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-modals"
              />
              <a
                href={project.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="absolute right-3 top-3 z-10 inline-flex items-center gap-1 rounded-lg border border-border bg-surface/90 px-2.5 py-1.5 text-xs font-semibold text-text shadow-sm backdrop-blur transition hover:border-accent hover:text-accent"
              >
                {t.openLive}
                <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </article>
      );
    })
  }
</div>

<style>
  /* Keep embedded demos scrollable without hijacking the page scroll. */
  article iframe {
    pointer-events: auto;
  }
</style>
