---
import { profile } from "../data/portfolio";

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const isDev = pathname.startsWith("/dev");

const standardLinks = [
  { label: "About", href: "#about" },
  { label: "Stack", href: "#stack" },
  { label: "Projects", href: "#projects" },
  { label: "Experience", href: "#experience" },
  { label: "Contact", href: "#contact" },
];

// In dev mode the code editor provides its own file tabs, so the nav links
// are hidden to avoid duplication.
const links = isDev ? [] : standardLinks;

const initials = profile.name
  .split(" ")
  .map((p) => p[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();
---

<header
  class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4 sm:px-6">
    <a
      href={isDev ? "/" : "#main"}
      class="flex items-center gap-2 font-semibold text-text"
    >
      <span
        class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-sm font-bold text-accent-contrast"
        >{initials}</span
      >
      <span class="hidden sm:inline">{profile.name}</span>
    </a>

    {
      links.length > 0 && (
        <>
          {/* Desktop links */}
          <ul class="hidden items-center gap-1 md:flex">
            {links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:bg-hover hover:text-text"
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>

          {/* Mobile toggle */}
          <button
            id="nav-toggle"
            type="button"
            aria-label="Open menu"
            aria-controls="nav-mobile"
            aria-expanded="false"
            class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-text transition hover:bg-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent md:hidden"
          >
            <svg class="nav-icon-open h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="nav-icon-close hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6 6 18M6 6l12 12" />
            </svg>
          </button>
        </>
      )
    }
  </nav>

  {/* Mobile menu panel */}
  {
    links.length > 0 && (
      <div
        id="nav-mobile"
        class="hidden border-t border-border bg-bg/95 backdrop-blur-md md:hidden"
      >
        <ul class="mx-auto flex max-w-5xl flex-col gap-1 px-4 py-3 sm:px-6">
          {links.map((l) => (
            <li>
              <a
                href={l.href}
                class="nav-mobile-link block rounded-lg px-3 py-2.5 text-base font-medium text-muted transition hover:bg-hover hover:text-text"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</header>

<script>
  // @ts-nocheck
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("nav-mobile");
  if (toggle && panel) {
    const openIcon = toggle.querySelector(".nav-icon-open");
    const closeIcon = toggle.querySelector(".nav-icon-close");

    const setOpen = (open) => {
      panel.classList.toggle("hidden", !open);
      openIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    };

    toggle.addEventListener("click", () =>
      setOpen(panel.classList.contains("hidden")),
    );

    // Close after picking a destination.
    panel.querySelectorAll(".nav-mobile-link").forEach((a) =>
      a.addEventListener("click", () => setOpen(false)),
    );

    // Close on Escape and when growing past the mobile breakpoint.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
    window.matchMedia("(min-width: 768px)").addEventListener("change", (e) => {
      if (e.matches) setOpen(false);
    });
  }
</script>
