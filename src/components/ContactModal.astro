---
import { getPortfolio } from "../data/portfolio";
import { getUi, DEFAULT_LANG } from "../data/i18n.js";

// Shared contact form modal used by both the standard and developer views.
// Open it from anywhere with either:
//   - an element carrying the `data-contact-open` attribute, or
//   - window.dispatchEvent(new CustomEvent("contact:open"))
// On a successful submit it dispatches `contact:sent` (detail: { email }).
const { lang = DEFAULT_LANG } = Astro.props;
const { socials } = getPortfolio(lang);
const t = getUi(lang).dev;

const email = (
  socials.find((s) => s.label === "Email")?.href || "mailto:harald.morjan@gmail.com"
).replace(/^mailto:/, "");

// Real backend: Web3Forms (https://web3forms.com). Set PUBLIC_WEB3FORMS_KEY in
// your .env to enable real sending; without it the form falls back to mailto:.
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY || "";
---

<div id="contact-modal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4">
  <div id="contact-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-title"
    class="relative w-full max-w-md overflow-hidden rounded-xl border border-border bg-surface shadow-2xl"
  >
    <!-- Window title bar -->
    <div class="flex items-center gap-2 border-b border-border px-4 py-2.5">
      <span class="flex gap-1.5">
        <button
          id="contact-close"
          type="button"
          aria-label={t.form.closeAria}
          class="h-3 w-3 rounded-full bg-red-400 transition hover:brightness-110"></button>
        <span class="h-3 w-3 rounded-full bg-yellow-400" aria-hidden="true"></span>
        <span class="h-3 w-3 rounded-full bg-green-400" aria-hidden="true"></span>
      </span>
      <span id="contact-title" class="mx-auto font-mono text-xs text-muted">{t.form.title}</span>
    </div>

    <form id="contact-form" class="space-y-4 p-5" novalidate>
      <div>
        <label for="contact-name" class="mb-1 block font-mono text-xs text-muted">{t.form.name}</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          placeholder={t.form.namePh}
          class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        />
      </div>
      <div>
        <label for="contact-email" class="mb-1 block font-mono text-xs text-muted">{t.form.email}</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          placeholder={t.form.emailPh}
          class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        />
      </div>
      <div>
        <label for="contact-message" class="mb-1 block font-mono text-xs text-muted">{t.form.message}</label>
        <textarea
          id="contact-message"
          name="message"
          rows="4"
          required
          placeholder={t.form.messagePh}
          class="w-full resize-y rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        ></textarea>
      </div>
      <p id="contact-error" class="hidden text-xs text-red-400"></p>
      <div class="flex items-center justify-end gap-2 pt-1">
        <button
          id="contact-cancel"
          type="button"
          class="rounded-lg border border-border px-4 py-2 text-sm text-muted transition hover:text-text"
        >
          {t.form.cancel}
        </button>
        <button
          id="contact-submit"
          type="submit"
          class="inline-flex items-center gap-2 rounded-lg bg-accent-strong px-4 py-2 text-sm font-medium text-accent-contrast transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60"
        >
          <svg class="contact-send-icon h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4Z" />
            <path d="M22 2 11 13" />
          </svg>
          <svg class="contact-spinner hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="3" class="opacity-25"></circle>
            <path d="M21 12a9 9 0 0 0-9-9" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path>
          </svg>
          <span class="contact-submit-label">{t.form.send}</span>
        </button>
      </div>
    </form>

    <!-- Success state -->
    <div id="contact-success" class="hidden flex-col items-center gap-2 px-6 py-10 text-center">
      <span class="mb-1 inline-flex h-12 w-12 items-center justify-center rounded-full bg-accent/15 text-accent">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </span>
      <p class="text-base font-semibold text-text">{t.form.successTitle}</p>
      <p class="max-w-xs text-sm text-muted">{t.form.successBody}</p>
    </div>
  </div>
</div>

<script define:vars={{ email, TF: t.form, accessKey: web3formsKey }}>
  // @ts-nocheck
  const modal = document.getElementById("contact-modal");
  const form = document.getElementById("contact-form");
  const nameEl = document.getElementById("contact-name");
  const emailEl = document.getElementById("contact-email");
  const messageEl = document.getElementById("contact-message");
  const errorEl = document.getElementById("contact-error");
  const successEl = document.getElementById("contact-success");
  const submitBtn = document.getElementById("contact-submit");
  const submitLabel = submitBtn?.querySelector(".contact-submit-label");
  const sendIcon = submitBtn?.querySelector(".contact-send-icon");
  const spinner = submitBtn?.querySelector(".contact-spinner");
  const fmt = (str, map) =>
    (str || "").replace(/\{(\w+)\}/g, (_, k) => (k in map ? map[k] : `{${k}}`));
  let lastFocused = null;

  const showForm = () => {
    form?.classList.remove("hidden");
    successEl?.classList.add("hidden");
    successEl?.classList.remove("flex");
  };
  const showSuccess = () => {
    form?.classList.add("hidden");
    successEl?.classList.remove("hidden");
    successEl?.classList.add("flex");
  };
  const setSending = (on) => {
    if (submitBtn) submitBtn.disabled = on;
    sendIcon?.classList.toggle("hidden", on);
    spinner?.classList.toggle("hidden", !on);
    if (submitLabel) submitLabel.textContent = on ? TF.sending || "Sending…" : TF.send || "Send";
  };

  function openContact() {
    if (!modal) return;
    lastFocused = document.activeElement;
    showForm();
    errorEl?.classList.add("hidden");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    setTimeout(() => nameEl?.focus(), 30);
  }
  function closeContact() {
    if (!modal) return;
    modal.classList.add("hidden");
    modal.classList.remove("flex");
    if (lastFocused && typeof lastFocused.focus === "function") lastFocused.focus();
  }

  // Open from any [data-contact-open] trigger or a custom event.
  document.addEventListener("click", (e) => {
    const trigger = e.target.closest?.("[data-contact-open]");
    if (trigger) {
      e.preventDefault();
      openContact();
    }
  });
  window.addEventListener("contact:open", openContact);

  document.getElementById("contact-close")?.addEventListener("click", closeContact);
  document.getElementById("contact-cancel")?.addEventListener("click", closeContact);
  document.getElementById("contact-backdrop")?.addEventListener("click", closeContact);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) closeContact();
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const name = (nameEl?.value || "").trim();
    const mail = (emailEl?.value || "").trim();
    const message = (messageEl?.value || "").trim();
    if (!name || !mail || !message || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(mail)) {
      if (errorEl) {
        errorEl.textContent = TF.error || "Please fill in your name, a valid email, and a message.";
        errorEl.classList.remove("hidden");
      }
      return;
    }
    errorEl?.classList.add("hidden");
    const subject = fmt(TF.subject || "Portfolio contact from {name}", { name });

    // No backend key configured → fall back to the visitor's mail client.
    if (!accessKey) {
      const bodyText = `${message}\n\n— ${name} (${mail})`;
      window.location.href = `mailto:${email}?subject=${encodeURIComponent(
        subject,
      )}&body=${encodeURIComponent(bodyText)}`;
      closeContact();
      form.reset();
      window.dispatchEvent(new CustomEvent("contact:sent", { detail: { email } }));
      return;
    }

    // Real send via Web3Forms.
    setSending(true);
    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json", Accept: "application/json" },
        body: JSON.stringify({
          access_key: accessKey,
          subject,
          from_name: name,
          name,
          email: mail,
          message,
          botcheck: "",
        }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && data.success) {
        showSuccess();
        form.reset();
        window.dispatchEvent(new CustomEvent("contact:sent", { detail: { email } }));
        setTimeout(() => {
          closeContact();
          showForm();
        }, 2400);
      } else {
        throw new Error((data && data.message) || "send failed");
      }
    } catch (err) {
      if (errorEl) {
        errorEl.textContent =
          TF.errorSend || "Couldn't send right now. Please try again or email me directly.";
        errorEl.classList.remove("hidden");
      }
    } finally {
      setSending(false);
    }
  });
</script>
