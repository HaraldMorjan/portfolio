---
import { Code } from "astro:components";
import { marked } from "marked";
import { profile, socials, techStack, projects } from "../../data/portfolio";
import SocialLinks from "../SocialLinks.astro";
import StackContent from "../sections/StackContent.astro";
import ExperienceContent from "../sections/ExperienceContent.astro";
import ProjectsContent from "../sections/ProjectsContent.astro";

// Section views are rendered with the exact same components as the standard view.
const viewMap = {
  stack: StackContent,
  experience: ExperienceContent,
  projects: ProjectsContent,
};

const { files } = Astro.props;

// Pre-render Markdown files so the "markdown" tabs show formatted output.
marked.setOptions({ gfm: true, breaks: false });
const rendered = {};
for (const f of files) {
  if (f.view === "markdown" && f.code) rendered[f.id] = marked.parse(f.code);
}

const langName = {
  ts: "TypeScript",
  md: "Markdown",
  bash: "Shell",
};
const badge = (lang) =>
  lang === "ts" ? "TS" : lang === "md" ? "MD" : lang.slice(0, 2).toUpperCase();
const badgeColor = (lang) =>
  lang === "ts" ? "text-blue-500" : lang === "md" ? "text-sky-500" : "text-accent";

const initials = profile.name
  .split(" ")
  .map((p) => p[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

// Data exposed to the interactive terminal (client-side).
const terminalData = {
  profile: {
    name: profile.name,
    role: profile.role,
    location: profile.location,
    bio: profile.bio,
  },
  socials,
  techStack,
  projects: projects.map((p) => ({ title: p.title, tags: p.tags })),
  files: files.map((f) => ({ filename: f.filename, id: f.id })),
};
---

<div
  class="code-editor flex flex-col overflow-hidden rounded-xl border border-border bg-surface shadow-sm md:h-[82vh] md:min-h-[34rem]"
>
  <!-- Title bar -->
  <div class="flex shrink-0 items-center gap-2 border-b border-border px-4 py-2.5">
    <span class="flex gap-1.5" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-red-400"></span>
      <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
      <span class="h-3 w-3 rounded-full bg-green-400"></span>
    </span>
    <span class="ml-2 font-mono text-xs text-muted">{profile.name} — portfolio</span>
  </div>

  <!-- Body: sidebar + main -->
  <div class="flex min-h-0 flex-1 flex-col md:flex-row">
    <!-- Explorer sidebar (profile + files).
         On mobile the <aside> uses `display:contents` so its children reflow as
         direct items of the body and can be reordered (profile, then the main
         editor, then terminal, then socials). On desktop it becomes the sidebar. -->
    <aside
      class="contents md:flex md:w-80 lg:w-96 md:shrink-0 md:flex-col md:overflow-y-auto md:border-r md:border-border md:bg-bg/40"
    >
      <!-- Profile -->
      <div class="order-1 border-b border-border bg-bg/40 p-4 md:order-none md:border-0 md:bg-transparent">
        <div class="flex items-center gap-3">
          {
            profile.avatar ? (
              <img
                src={profile.avatar}
                alt={profile.name}
                class="h-12 w-12 rounded-lg object-cover"
              />
            ) : (
              <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent text-base font-bold text-accent-contrast">
                {initials}
              </div>
            )
          }
          <div class="min-w-0">
            <p class="truncate font-semibold text-text">{profile.name}</p>
            <p class="truncate font-mono text-xs text-accent">{profile.role}</p>
          </div>
        </div>
        <p class="mt-3 inline-flex items-center gap-1.5 font-mono text-xs text-muted">
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {profile.location}
        </p>
        <p class="mt-3 text-sm leading-relaxed text-muted">{profile.bio}</p>
      </div>

      <!-- Terminal: an OS-style terminal window. On mobile it's a collapsible
           panel (collapsed by default); on desktop it always fills the sidebar.
           A plain div + button is used instead of <details> so the flex chain
           (md:flex-1) reaches the terminal reliably across browsers. -->
      <div class="term-details order-3 flex min-h-0 flex-col border-t border-border p-4 md:order-none md:flex-1 is-collapsed">
        <button
          type="button"
          aria-expanded="false"
          aria-controls="term-window"
          class="term-toggle mb-3 flex w-full cursor-pointer items-center justify-between gap-2 rounded-lg border border-border bg-bg px-3 py-2 font-mono text-xs text-muted transition hover:text-text"
        >
          <span class="flex items-center gap-1.5">
            <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 17 6-6-6-6" /><path d="M12 19h8" /></svg>
            Open terminal
          </span>
          <svg viewBox="0 0 24 24" class="term-chevron h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
        </button>
        <div id="term-window" class="term-content flex h-72 min-h-0 flex-col overflow-hidden rounded-xl border border-black/50 shadow-xl ring-1 ring-white/5 md:h-auto md:flex-1">
          <!-- Window title bar -->
          <div class="relative flex shrink-0 items-center border-b border-black/40 bg-gradient-to-b from-[#272d39] to-[#1c212b] px-3 py-2">
            <span class="flex gap-1.5" aria-hidden="true">
              <span class="h-3 w-3 rounded-full bg-[#ff5f57] ring-1 ring-black/20"></span>
              <span class="h-3 w-3 rounded-full bg-[#febc2e] ring-1 ring-black/20"></span>
              <span class="h-3 w-3 rounded-full bg-[#28c840] ring-1 ring-black/20"></span>
            </span>
            <span class="pointer-events-none absolute inset-x-0 flex items-center justify-center gap-1.5 text-center font-mono text-[0.7rem] font-medium text-slate-400">
              <svg viewBox="0 0 24 24" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 17 6-6-6-6" /><path d="M12 19h8" /></svg>
              zsh — portfolio
            </span>
          </div>
          <!-- Terminal body (interactive) -->
          <div class="term-body flex-1 cursor-text overflow-auto bg-[#0b0f17] p-3.5 font-mono text-xs leading-[1.65] text-slate-200 [scrollbar-color:theme(colors.slate.700)_transparent] [scrollbar-width:thin] selection:bg-emerald-500/30 selection:text-emerald-50">
            <div id="term-out" class="space-y-1"></div>
            <div class="mt-0.5 flex flex-wrap items-center">
              <span class="shrink-0 font-medium text-emerald-400">visitor@portfolio</span><span class="text-slate-500">:</span><span class="text-sky-400">~</span><span class="mr-1.5 text-slate-500">$</span>
              <span id="term-typed" class="whitespace-pre-wrap break-all text-slate-100"></span><span
                id="term-cursor"
                class="cursor-blink inline-block h-3.5 w-[7px] translate-y-0.5 rounded-[1px] bg-emerald-400 align-middle"
              ></span>
              <input
                id="term-input"
                class="h-0 w-0 border-0 bg-transparent p-0 opacity-0"
                autocomplete="off"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                aria-label="Terminal input"
              />
            </div>
          </div>
        </div>
      </div>
      <script type="application/json" id="term-data" is:inline set:html={JSON.stringify(terminalData)} />

      <!-- Socials footer -->
      <div class="order-4 shrink-0 border-t border-border bg-bg/40 p-4 md:order-none md:bg-transparent">
        <SocialLinks />
      </div>
    </aside>

    <!-- Main column: tabs + code + terminal -->
    <div class="order-2 flex min-h-0 min-w-0 flex-1 flex-col md:order-none">
      <!-- Tab bar -->
      <div role="tablist" aria-label="Open files" class="flex shrink-0 overflow-x-auto border-b border-border bg-bg/40">
        {
          files.map((f, i) => (
            <button
              type="button"
              role="tab"
              id={`tab-${f.id}`}
              aria-controls={f.id}
              aria-selected={i === 0 ? "true" : "false"}
              class="ce-tab flex shrink-0 items-center gap-2 border-r border-border px-4 py-2 font-mono text-xs text-muted transition hover:text-text data-[active=true]:bg-surface data-[active=true]:text-text data-[active=true]:shadow-[inset_0_2px_0_0_var(--accent)]"
              data-target={f.id}
              data-active={i === 0 ? "true" : "false"}
            >
              <span class={`text-[0.65rem] font-bold ${badgeColor(f.lang)}`}>{badge(f.lang)}</span>
              {f.filename}
            </button>
          ))
        }
      </div>

      <!-- Code panes (scrollable) -->
      <div class="min-h-0 flex-1 overflow-auto">
        {
          files.map((f, i) => {
            const SectionView = f.view in viewMap ? viewMap[f.view] : null;
            return (
              <div
                id={f.id}
                role="tabpanel"
                aria-labelledby={`tab-${f.id}`}
                data-langname={
                  f.view === "code" ? langName[f.lang] ?? f.lang : "Markdown (preview)"
                }
                class:list={["ce-pane", i !== 0 && "hidden"]}
              >
                {f.view === "code" && f.code && (
                  <Code
                    code={f.code}
                    lang={f.lang}
                    themes={{ light: "github-light", dark: "github-dark" }}
                    defaultColor={false}
                  />
                )}
                {f.view === "markdown" && (
                  <div class="md-prose px-6 py-7 sm:px-8" set:html={rendered[f.id]} />
                )}
                {SectionView && (
                  <div class="px-6 py-7 sm:px-8">
                    <SectionView />
                  </div>
                )}
              </div>
            );
          })
        }
      </div>

    </div>
  </div>

  <!-- Status bar -->
  <div class="flex shrink-0 items-center justify-between gap-4 bg-accent px-4 py-1 font-mono text-[0.7rem] text-accent-contrast">
    <span class="flex items-center gap-1.5">
      <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="6" cy="6" r="2.5"></circle>
        <circle cx="18" cy="18" r="2.5"></circle>
        <path d="M6 8.5v3a4 4 0 0 0 4 4h5.5"></path>
      </svg>
      main
    </span>
    <span class="flex items-center gap-4">
      <span class="ce-status-lang">{langName[files[0]?.lang] ?? ""}</span>
      <span class="hidden sm:inline">UTF-8</span>
      <span class="hidden sm:inline">Ln 1, Col 1</span>
    </span>
  </div>
</div>

<!-- Contact form modal (opened by the `contactme` terminal command) -->
<div id="contact-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
  <div id="contact-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div
    role="dialog"
    aria-modal="true"
    aria-labelledby="contact-title"
    class="relative w-full max-w-md overflow-hidden rounded-xl border border-border bg-surface shadow-2xl"
  >
    <!-- Window title bar -->
    <div class="flex items-center gap-2 border-b border-border px-4 py-2.5">
      <span class="flex gap-1.5">
        <button
          id="contact-close"
          type="button"
          aria-label="Close contact form"
          class="h-3 w-3 rounded-full bg-red-400 transition hover:brightness-110"></button>
        <span class="h-3 w-3 rounded-full bg-yellow-400" aria-hidden="true"></span>
        <span class="h-3 w-3 rounded-full bg-green-400" aria-hidden="true"></span>
      </span>
      <span id="contact-title" class="mx-auto font-mono text-xs text-muted">contact — new message</span>
    </div>

    <form id="contact-form" class="space-y-4 p-5" novalidate>
      <div>
        <label for="contact-name" class="mb-1 block font-mono text-xs text-muted">name</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          placeholder="Your name"
          class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        />
      </div>
      <div>
        <label for="contact-email" class="mb-1 block font-mono text-xs text-muted">email</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          class="w-full rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        />
      </div>
      <div>
        <label for="contact-message" class="mb-1 block font-mono text-xs text-muted">message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="4"
          required
          placeholder="Hi Harald, …"
          class="w-full resize-y rounded-lg border border-border bg-bg px-3 py-2 text-sm text-text outline-none transition placeholder:text-muted/60 focus:border-accent focus:ring-2 focus:ring-accent/30"
        ></textarea>
      </div>
      <p id="contact-error" class="hidden text-xs text-red-400"></p>
      <div class="flex items-center justify-end gap-2 pt-1">
        <button
          id="contact-cancel"
          type="button"
          class="rounded-lg border border-border px-4 py-2 text-sm text-muted transition hover:text-text"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-accent-contrast transition hover:opacity-90"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m22 2-7 20-4-9-9-4Z" />
            <path d="M22 2 11 13" />
          </svg>
          Send
        </button>
      </div>
    </form>
  </div>
</div>

<style>
  /* Collapsed state (mobile default) hides the terminal window. */
  .term-details.is-collapsed > .term-content {
    display: none;
  }
  .term-chevron {
    transition: transform 0.2s ease;
  }
  .term-toggle[aria-expanded="true"] .term-chevron {
    transform: rotate(180deg);
  }
  /* On desktop the terminal always fills the sidebar and the toggle is hidden,
     regardless of the collapsed class. */
  @media (min-width: 768px) {
    .term-toggle {
      display: none !important;
    }
    .term-details > .term-content {
      display: flex !important;
    }
  }
</style>

<script>
  // @ts-nocheck
  const editor = document.querySelector(".code-editor");
  if (editor) {
    const panes = Array.from(editor.querySelectorAll(".ce-pane"));
    const tabs = Array.from(editor.querySelectorAll(".ce-tab"));
    const files = Array.from(editor.querySelectorAll(".ce-file"));
    const statusLang = editor.querySelector(".ce-status-lang");

    // The terminal collapses on mobile and is always expanded on desktop.
    const termDetails = editor.querySelector(".term-details");
    const termToggle = editor.querySelector(".term-toggle");
    if (termDetails && termToggle) {
      const desktopMq = window.matchMedia("(min-width: 768px)");
      const setCollapsed = (collapsed) => {
        termDetails.classList.toggle("is-collapsed", collapsed);
        termToggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
      };
      // Expanded on desktop, collapsed on mobile; re-sync on breakpoint change.
      const syncTerminal = () => setCollapsed(!desktopMq.matches);
      syncTerminal();
      desktopMq.addEventListener("change", syncTerminal);
      termToggle.addEventListener("click", () =>
        setCollapsed(!termDetails.classList.contains("is-collapsed")),
      );
    }

    const setActive = (els, id) =>
      els.forEach((e) => (e.dataset.active = e.dataset.target === id ? "true" : "false"));

    function activate(id, scroll = false) {
      if (!panes.some((p) => p.id === id)) return;
      panes.forEach((p) => p.classList.toggle("hidden", p.id !== id));
      setActive(tabs, id);
      setActive(files, id);
      tabs.forEach((t) =>
        t.setAttribute("aria-selected", t.dataset.target === id ? "true" : "false"),
      );
      const pane = panes.find((p) => p.id === id);
      if (statusLang && pane) statusLang.textContent = pane.dataset.langname || "";
      if (scroll) editor.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    [...tabs, ...files].forEach((el) =>
      el.addEventListener("click", () => activate(el.dataset.target)),
    );

    // Allow nav file links (#about-ts, ...) to switch tabs.
    window.addEventListener("hashchange", () => activate(location.hash.slice(1), true));
    const initial = location.hash.slice(1);
    if (initial) activate(initial);

    // ---- interactive terminal ---------------------------------------------
    const termData = JSON.parse(
      document.getElementById("term-data")?.textContent || "{}",
    );
    const out = editor.querySelector("#term-out");
    const input = editor.querySelector("#term-input");
    const typed = editor.querySelector("#term-typed");
    const body = editor.querySelector(".term-body");

    if (out && input && typed && body) {
      const tFiles = termData.files || [];
      const tSocials = termData.socials || [];
      const history = [];
      let histIdx = 0;
      const CONTACT_EMAIL = "harald.morjan@gmail.com";

      const esc = (s) =>
        s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

      const printText = (text, cls = "") => {
        const d = document.createElement("div");
        d.className = ("whitespace-pre-wrap break-words " + cls).trim();
        d.textContent = text;
        out.appendChild(d);
      };
      const printHtml = (html, cls = "") => {
        const d = document.createElement("div");
        if (cls) d.className = cls;
        d.innerHTML = html;
        out.appendChild(d);
      };
      const echo = (cmd) => {
        const d = document.createElement("div");
        d.innerHTML = `<span class="font-medium text-emerald-400">visitor@portfolio</span><span class="text-slate-500">:</span><span class="text-sky-400">~</span><span class="text-slate-500">$</span> <span class="text-slate-100">${esc(cmd)}</span>`;
        out.appendChild(d);
      };
      const scrollDown = () => (body.scrollTop = body.scrollHeight);
      const findFile = (name) =>
        tFiles.find((f) => f.filename.toLowerCase() === (name || "").toLowerCase());

      const hh = esc;
      const grid = (rows) =>
        `<div class="grid grid-cols-[auto_1fr] gap-x-4 gap-y-0.5">${rows}</div>`;

      const skills = () =>
        termData.techStack
          .map(
            (c) =>
              `<div class="mt-1.5 text-sky-400">${hh(c.category)}</div>` +
              `<div class="pl-3 text-slate-400">${hh(c.items.join(", "))}</div>`,
          )
          .join("");
      const socialsList = () =>
        grid(
          tSocials
            .map(
              (s) =>
                `<span class="text-emerald-400">${hh(s.label)}</span>` +
                `<span class="break-all text-sky-400">${hh(s.href.replace(/^mailto:/, ""))}</span>`,
            )
            .join(""),
        );

      const helpRows = [
        ["help", "show this help"],
        ["whoami", "name and role"],
        ["about", "short bio"],
        ["skills", "tech stack"],
        ["projects", "list projects"],
        ["socials", "contact links"],
        ["ls", "list files"],
        ["cat &lt;file&gt;", "print a file"],
        ["open &lt;file&gt;", "open a file"],
        ["open &lt;social&gt;", "open a link"],
        ["contactme", "open a contact form"],
        ["clear", "clear screen"],
      ];

      const commands = {
        help: () =>
          `<div class="mb-1 text-slate-500"># available commands</div>` +
          grid(
            helpRows
              .map(
                ([n, d]) =>
                  `<span class="whitespace-nowrap text-emerald-400">${n}</span><span class="text-slate-400">${d}</span>`,
              )
              .join(""),
          ),
        whoami: () =>
          `<span class="font-semibold text-slate-100">${hh(termData.profile.name)}</span> ` +
          `<span class="text-slate-500">—</span> ` +
          `<span class="text-emerald-400">${hh(termData.profile.role)}</span>`,
        about: () =>
          `<div class="text-slate-300">${hh(termData.profile.bio)}</div>` +
          `<div class="mt-1 text-slate-400">📍 ${hh(termData.profile.location)}</div>`,
        skills,
        stack: skills,
        projects: () =>
          termData.projects
            .map(
              (p) =>
                `<div class="mt-0.5 pl-4 -indent-4"><span class="text-emerald-400">▸</span> ` +
                `<span class="text-slate-100">${hh(p.title)}</span> ` +
                `<span class="text-slate-500">[${hh(p.tags.join(", "))}]</span></div>`,
            )
            .join(""),
        socials: socialsList,
        contact: socialsList,
        contactme: () => {
          openContact();
          return `<span class="text-slate-400">Opening contact form… </span><span class="text-slate-500">(or just email </span><span class="text-sky-400">${CONTACT_EMAIL}</span><span class="text-slate-500">)</span>`;
        },
        hireme: () => commands.contactme(),
        ls: () =>
          tFiles
            .map((f) => `<span class="text-sky-400">${hh(f.filename)}</span>`)
            .join('<span class="text-slate-600">  </span>'),
        date: () => `<span class="text-slate-400">${hh(new Date().toString())}</span>`,
        clear: () => {
          out.innerHTML = "";
          return "";
        },
      };

      function run(raw) {
        echo(raw);
        const line = raw.trim();
        if (!line) return;
        history.push(line);
        histIdx = history.length;
        const parts = line.split(/\s+/);
        const cmd = parts[0].toLowerCase();
        const arg = parts[1] || "";

        if (cmd === "cat") {
          const f = findFile(arg);
          if (!f) printText(`cat: ${arg}: No such file`, "text-red-400");
          else {
            const el = document.getElementById(f.id);
            printText((el?.textContent || "").trim(), "text-slate-300");
          }
        } else if (cmd === "open" || cmd === "code") {
          const f = findFile(arg);
          if (f) {
            activate(f.id);
            printHtml(
              `<span class="text-slate-400">Opening </span><span class="text-sky-400">${hh(f.filename)}</span><span class="text-slate-400"> in the editor…</span>`,
            );
          } else {
            const a = arg.toLowerCase();
            const social = tSocials.find(
              (s) => s.label.toLowerCase() === a || s.label.toLowerCase().startsWith(a),
            );
            if (social && a) {
              window.open(social.href, "_blank", "noopener");
              printText(`Opening ${social.label}…`, "text-slate-400");
            } else {
              printText(`open: ${arg}: not found`, "text-red-400");
            }
          }
        } else if (cmd === "sudo") {
          printText(
            "visitor is not in the sudoers file. This incident will be reported.",
            "text-red-400",
          );
        } else if (commands[cmd]) {
          const res = commands[cmd]();
          if (res) printHtml(res);
        } else {
          printText(`command not found: ${parts[0]}. Type 'help'.`, "text-red-400");
        }
      }

      printHtml(
        `<span class="text-slate-400">Welcome! Type </span><span class="text-emerald-400">help</span><span class="text-slate-400"> to get started.</span>`,
      );

      // ---- contact form modal -----------------------------------------------
      const modal = document.getElementById("contact-modal");
      const form = document.getElementById("contact-form");
      const nameEl = document.getElementById("contact-name");
      const emailEl = document.getElementById("contact-email");
      const messageEl = document.getElementById("contact-message");
      const errorEl = document.getElementById("contact-error");

      function openContact() {
        if (!modal) return;
        modal.classList.remove("hidden");
        modal.classList.add("flex");
        if (errorEl) errorEl.classList.add("hidden");
        setTimeout(() => nameEl?.focus(), 30);
      }
      function closeContact() {
        if (!modal) return;
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        input?.focus();
      }

      document.getElementById("contact-close")?.addEventListener("click", closeContact);
      document.getElementById("contact-cancel")?.addEventListener("click", closeContact);
      document.getElementById("contact-backdrop")?.addEventListener("click", closeContact);
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal && !modal.classList.contains("hidden")) closeContact();
      });

      form?.addEventListener("submit", (e) => {
        e.preventDefault();
        const name = (nameEl?.value || "").trim();
        const email = (emailEl?.value || "").trim();
        const message = (messageEl?.value || "").trim();

        if (!name || !email || !message || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          if (errorEl) {
            errorEl.textContent = "Please fill in your name, a valid email, and a message.";
            errorEl.classList.remove("hidden");
          }
          return;
        }

        const subject = `Portfolio contact from ${name}`;
        const bodyText = `${message}\n\n— ${name} (${email})`;
        const href = `mailto:${CONTACT_EMAIL}?subject=${encodeURIComponent(
          subject,
        )}&body=${encodeURIComponent(bodyText)}`;
        window.location.href = href;

        closeContact();
        form.reset();
        printHtml(
          `<span class="text-emerald-400">✓</span> <span class="text-slate-400">Opening your email client to send the message to </span><span class="text-sky-400">${CONTACT_EMAIL}</span><span class="text-slate-400">…</span>`,
        );
        scrollDown();
      });

      body.addEventListener("click", () => input.focus());
      input.addEventListener("input", () => (typed.textContent = input.value));
      input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          run(input.value);
          input.value = "";
          typed.textContent = "";
          scrollDown();
        } else if (e.key === "ArrowUp") {
          if (history.length) {
            histIdx = Math.max(0, histIdx - 1);
            input.value = history[histIdx] || "";
            typed.textContent = input.value;
            e.preventDefault();
          }
        } else if (e.key === "ArrowDown") {
          if (history.length) {
            histIdx = Math.min(history.length, histIdx + 1);
            input.value = history[histIdx] || "";
            typed.textContent = input.value;
            e.preventDefault();
          }
        }
      });
    }
  }
</script>
