---
import { getPortfolio } from "../data/portfolio";
import { DEFAULT_LANG } from "../data/i18n.js";
import ExperienceContent from "./sections/ExperienceContent.astro";

const { lang = DEFAULT_LANG } = Astro.props;
const { experience } = getPortfolio(lang);
---

{
  experience.length > 0 && (
    <section id="experience" class="border-y border-border bg-surface/50">
      <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
        <ExperienceContent lang={lang} />
      </div>
    </section>
  )
}
