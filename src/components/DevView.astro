---
import Layout from "../layouts/Layout.astro";
import Footer from "./Footer.astro";
import ThemeStudio from "./ThemeStudio.astro";
import DevModeButton from "./DevModeButton.astro";
import DarkModeButton from "./DarkModeButton.astro";
import LangButton from "./LangButton.astro";
import CodeEditor from "./dev/CodeEditor.astro";
import CommandPalette from "./dev/CommandPalette.astro";
import ContactModal from "./ContactModal.astro";
import { getPortfolio } from "../data/portfolio";
import { getUi, DEFAULT_LANG } from "../data/i18n.js";
import { aboutTs, readmeMd } from "../data/devCode";

const { lang = DEFAULT_LANG } = Astro.props;
const portfolio = getPortfolio(lang);
const { profile } = portfolio;
const ui = getUi(lang);
const t = ui.dev;

const files = [
  { id: "about-ts", filename: "about.ts", lang: "ts", view: "code", code: aboutTs(portfolio, t) },
  { id: "stack-md", filename: "stack.md", lang: "md", view: "stack" },
  { id: "experience-md", filename: "experience.md", lang: "md", view: "experience" },
  { id: "projects-md", filename: "projects.md", lang: "md", view: "projects" },
  { id: "readme-md", filename: "README.md", lang: "md", view: "markdown", code: readmeMd(portfolio, t) },
];
---

<Layout
  lang={lang}
  title={`${profile.name} - ${ui.devViewTitle}`}
  description={profile.tagline}
>
  <main id="main" class="mx-auto max-w-[1800px] px-4 py-8 sm:px-6 sm:py-10">
    <CodeEditor files={files} lang={lang} />
  </main>
  <CommandPalette files={files} lang={lang} />
  <ContactModal lang={lang} />
  <Footer lang={lang} />
  <DarkModeButton />
  <DevModeButton lang={lang} />
  <LangButton lang={lang} />
  <ThemeStudio />
</Layout>
