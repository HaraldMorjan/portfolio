---
// Lighthouse scorecard — four ring gauges (Performance, Accessibility, Best
// Practices, SEO) styled after the real Lighthouse report, color-coded by
// Lighthouse's own thresholds. Numbers come from src/data/lighthouse.js.
import { getUi, DEFAULT_LANG } from "../data/i18n.js";
import { lighthouse, scoreColor, reportUrl } from "../data/lighthouse.js";

const { lang = DEFAULT_LANG, class: className = "" } = Astro.props;
const t = getUi(lang).lighthouse;
const report = reportUrl();

const items = [
  { label: t.perf, score: lighthouse.scores.performance },
  { label: t.a11y, score: lighthouse.scores.accessibility },
  { label: t.bp, score: lighthouse.scores.bestPractices },
  { label: t.seo, score: lighthouse.scores.seo },
];

// Ring geometry.
const R = 16;
const CIRC = 2 * Math.PI * R;
---

<section
  aria-label={`${t.title} — ${t.note}`}
  class:list={["flex flex-col items-center gap-3", className]}
>
  <div class="flex items-center gap-1.5 font-mono text-xs font-semibold uppercase tracking-widest text-muted">
    <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7c.6.5 1 1.3 1 2.1V17h6v-.2c0-.8.4-1.6 1-2.1A7 7 0 0 0 12 2z"></path>
    </svg>
    {t.title}
  </div>

  <ul class="flex flex-wrap items-start justify-center gap-x-6 gap-y-4">
    {
      items.map((it) => {
        const color = scoreColor(it.score);
        const offset = CIRC * (1 - it.score / 100);
        return (
          <li class="flex w-16 flex-col items-center gap-1.5">
            <span
              role="img"
              aria-label={`${it.label}: ${it.score}/100`}
              class="relative inline-flex h-12 w-12 items-center justify-center"
            >
              <svg class="h-12 w-12 -rotate-90" viewBox="0 0 40 40" aria-hidden="true">
                <circle cx="20" cy="20" r={R} fill="none" stroke="currentColor" stroke-width="3" class="text-border" />
                <circle
                  cx="20"
                  cy="20"
                  r={R}
                  fill="none"
                  stroke={color}
                  stroke-width="3"
                  stroke-linecap="round"
                  stroke-dasharray={CIRC}
                  stroke-dashoffset={offset}
                />
              </svg>
              <span class="absolute text-sm font-bold tabular-nums" style={`color:${color}`}>
                {it.score}
              </span>
            </span>
            <span class="text-center text-[0.7rem] leading-tight text-muted">{it.label}</span>
          </li>
        );
      })
    }
  </ul>

  <a
    href={report}
    target="_blank"
    rel="noopener noreferrer"
    title={t.viewReport}
    class="group inline-flex items-center gap-1.5 font-mono text-[0.65rem] text-muted/80 transition hover:text-accent"
  >
    <span>{t.note}{lighthouse.formFactor ? ` · ${lighthouse.formFactor}` : ""} · {lighthouse.measuredAt}</span>
    <svg class="h-3 w-3 transition group-hover:-translate-y-0.5 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M7 17 17 7M7 7h10v10"></path>
    </svg>
    <span class="sr-only">{t.viewReport}</span>
  </a>
</section>
