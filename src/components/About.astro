---
import { getPortfolio } from "../data/portfolio";
import { getUi, DEFAULT_LANG } from "../data/i18n.js";

const { lang = DEFAULT_LANG } = Astro.props;
const { profile } = getPortfolio(lang);
const t = getUi(lang).about;

const paragraphs =
  profile.about && profile.about.length > 0 ? profile.about : [profile.bio];
---

<section id="about" class="mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
  <div class="grid gap-8 md:grid-cols-3">
    <div class="md:col-span-1">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">
        {t.eyebrow}
      </h2>
      <p class="mt-2 text-2xl font-bold text-text">{t.title}</p>

      {
        profile.topSkills && profile.topSkills.length > 0 && (
          <div class="mt-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-muted">
              {t.topSkills}
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {profile.topSkills.map((skill) => (
                <li>
                  <span class="inline-flex items-center rounded-md border border-border bg-surface px-2.5 py-1 text-sm font-medium text-text">
                    {skill}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )
      }
    </div>

    <div class="md:col-span-2">
      <div class="space-y-4 text-lg leading-relaxed text-muted">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <p class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-muted">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        {profile.location}
      </p>

      {
        profile.mobility && (
          <p class="mt-4 flex items-start gap-2 rounded-xl border border-border bg-surface/60 p-4 text-sm leading-relaxed text-muted">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <path d="M2 12h20" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
            <span>{profile.mobility}</span>
          </p>
        )
      }
    </div>
  </div>
</section>
